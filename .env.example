# ============================================================
# 数据库 - Neon (Serverless PostgreSQL)
# ============================================================
# 注册 Neon: https://neon.tech
# 创建项目后，复制 Connection String 到这里
# 推荐使用 Pooled connection（带 -pooler 后缀）
#
# 格式: postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
#
# 示例（替换为你自己的）:
# DATABASE_URL=postgresql://alex:AbC123dEf@ep-cool-darkness-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

DATABASE_URL=

# 直连连接（用于 Drizzle Kit / 迁移工具，不走连接池）
# 如果 DATABASE_URL 已经是 pooled 连接，这里填直连连接
# Drizzle 的 schema push 不支持连接池模式
DIRECT_DATABASE_URL=

# ============================================================
# Auth (Better Auth)
# ============================================================
# 生成一个安全的 secret: openssl rand -hex 32
BETTER_AUTH_SECRET=your-secret-key-here-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000

# ============================================================
# OAuth (可选)
# ============================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# AI (可选)
# ============================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000
